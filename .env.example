# Required — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=your_64_char_hex_key_here

DATABASE_URL=postgresql://ttc-postgres-user:ttc-postgres-user@localhost:51214/ttc-postgres-db

# Must be >= 32 chars
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=your_cookie_secret_min_32_chars_here

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

FRONTEND_URL=http://localhost:5173

SENTRY_DSN=your_sentry_dsn

# Optional — SMTP for password reset emails (dev: reset URL logged to console if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ttc.local

# Optional — defaults shown
AUDIT_RETENTION_DAYS=90
CLOCKIFY_API_URL=https://api.clockify.me/api/v1
REDIS_URL=redis://localhost:6379

# Optional — HubSpot OAuth integration
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/hubspot/auth/callback
HUBSPOT_WEBHOOK_SECRET=
